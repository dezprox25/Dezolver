# =============================================================================
#  Dezolver Frontend — Environment Variables Reference
#  Copy this file to .env.development or .env.production and fill in values.
#
#  VITE_ prefix is required — Vite only exposes variables with this prefix
#  to the browser bundle via import.meta.env.VITE_*
#
#  Never commit real secrets in .env files.
#  .env.development and .env.production are git-ignored.
# =============================================================================


# -----------------------------------------------------------------------------
# 🌍 Environment
# -----------------------------------------------------------------------------

# Active environment: development | staging | production
# Used by config/index.ts to resolve isDevelopment / isProduction flags
VITE_ENV=development


# -----------------------------------------------------------------------------
# 🔌 API — Backend connection
# -----------------------------------------------------------------------------

# Full base URL for every Axios request in services/api.ts
# The /api suffix is required — all backend routes are mounted under /api
#
#   development : http://localhost:3000/api
#                 (Vite proxy in vite.config.ts also forwards /api → localhost:3000)
#
#   staging     : https://dezolver-backend-staging.onrender.com/api
#
#   production  : https://dezolver-backend.onrender.com/api
#                 (set in render.yaml as VITE_API_URL — do NOT add a trailing slash)
VITE_API_URL=http://localhost:3000/api

# Axios request timeout in milliseconds (default: 10000 = 10 s)
VITE_API_TIMEOUT=10000

# Axios timeout for file-upload requests in milliseconds (default: 30000 = 30 s)
VITE_UPLOAD_TIMEOUT=30000


# -----------------------------------------------------------------------------
# 🔁 WebSocket — Real-time connection
# -----------------------------------------------------------------------------

# Socket.io server URL (no path needed — socket.io handles /socket.io internally)
#
#   development : ws://localhost:3000
#   staging     : wss://dezolver-backend-staging.onrender.com
#   production  : wss://dezolver-backend.onrender.com
VITE_WS_URL=ws://localhost:3000


# -----------------------------------------------------------------------------
# 🏷️  Application metadata
# -----------------------------------------------------------------------------

VITE_APP_NAME=Dezolver
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Competitive coding platform for developers


# -----------------------------------------------------------------------------
# 🔐 Authentication
# -----------------------------------------------------------------------------

# localStorage key used to persist the JWT access token
VITE_AUTH_TOKEN_KEY=techfolks_auth_token

# localStorage key used to persist the JWT refresh token
VITE_REFRESH_TOKEN_KEY=techfolks_refresh_token

# Session lifetime in milliseconds before the user is logged out (default: 7 days)
VITE_SESSION_TIMEOUT=604800000

# Number of failed login attempts before the form is locked
VITE_MAX_LOGIN_ATTEMPTS=5


# -----------------------------------------------------------------------------
# 🚩 Feature Flags
# Toggle entire sections of the UI without a code change.
# Set to "true" to enable, "false" to disable.
# -----------------------------------------------------------------------------

VITE_ENABLE_GROUPS=true
VITE_ENABLE_CONTESTS=true
VITE_ENABLE_DISCUSSIONS=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_ADMIN_CONSOLE=true
VITE_ENABLE_SOCIAL_AUTH=true
VITE_ENABLE_CODE_EXECUTION=true


# -----------------------------------------------------------------------------
# 🎨 UI / Theme
# -----------------------------------------------------------------------------

# Default colour scheme applied on first visit: light | dark | system
VITE_DEFAULT_THEME=system

# Prefix for every key written to localStorage (avoids collisions with other apps)
VITE_STORAGE_PREFIX=techfolks

# Number of items shown per page in lists and tables
VITE_DEFAULT_PAGE_SIZE=20

# Hard upper limit for page size (guards against accidental &limit=9999 calls)
VITE_MAX_PAGE_SIZE=100


# -----------------------------------------------------------------------------
# ⚡ Rate Limits
# These mirror the backend limits and are used for client-side throttle UX.
# -----------------------------------------------------------------------------

# Maximum code submissions the UI will allow per minute before showing a warning
VITE_MAX_SUBMISSIONS_PER_MINUTE=5


# -----------------------------------------------------------------------------
# 🖊️  Monaco Editor
# -----------------------------------------------------------------------------

# Comma-separated list of Monaco themes available in the editor toolbar
VITE_MONACO_THEMES=vs-dark,vs-light,hc-black


# -----------------------------------------------------------------------------
# 🔗 External Links
# -----------------------------------------------------------------------------

VITE_GITHUB_URL=https://github.com/dezprox25/Dezolver
VITE_DOCS_URL=https://docs.dezolver.com
VITE_SUPPORT_EMAIL=support@dezolver.com


# -----------------------------------------------------------------------------
# 🔑 Third-Party Services
# These values are intentionally left blank — set them per environment.
# Never commit real client IDs or tracking IDs.
# -----------------------------------------------------------------------------

# GitHub OAuth App — Client ID (from https://github.com/settings/developers)
VITE_GITHUB_CLIENT_ID=

# Google OAuth 2.0 — Client ID (from https://console.cloud.google.com)
VITE_GOOGLE_CLIENT_ID=

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_TRACKING_ID=

# Sentry — DSN for frontend error tracking (from https://sentry.io)
VITE_SENTRY_DSN=
