# =============================================================
#  Dezolver — Frontend Production Environment
#  Used by: vite build (npm run build)
#  Injected by Render at build time via render.yaml envVars
# =============================================================

# ── Environment ───────────────────────────────────────────────
VITE_ENV=production

# ── App Info ──────────────────────────────────────────────────
VITE_APP_NAME=Dezolver
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Competitive coding platform for developers

# ── API ───────────────────────────────────────────────────────
# Full backend URL including /api prefix.
# Every Axios call in api.ts uses this as baseURL, so a call to
# "/auth/login" resolves to:
#   https://dezolver-backend.onrender.com/api/auth/login
# which matches app.use('/api/auth', authRoutes) on the backend.
VITE_API_URL=https://dezolver-backend.onrender.com/api

# Request timeouts (milliseconds)
VITE_API_TIMEOUT=15000
VITE_UPLOAD_TIMEOUT=60000

# ── WebSocket ─────────────────────────────────────────────────
# Must use wss:// (secure WebSocket) in production.
# No path needed — socket.io client handles its own handshake path.
VITE_WS_URL=wss://dezolver-backend.onrender.com

# ── Auth ──────────────────────────────────────────────────────
VITE_AUTH_TOKEN_KEY=techfolks_auth_token
VITE_REFRESH_TOKEN_KEY=techfolks_refresh_token
# Session timeout: 7 days in milliseconds
VITE_SESSION_TIMEOUT=604800000
VITE_MAX_LOGIN_ATTEMPTS=5

# ── Feature Flags ─────────────────────────────────────────────
VITE_ENABLE_GROUPS=true
VITE_ENABLE_CONTESTS=true
VITE_ENABLE_DISCUSSIONS=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_ADMIN_CONSOLE=true
VITE_ENABLE_SOCIAL_AUTH=true
VITE_ENABLE_CODE_EXECUTION=true

# ── UI ────────────────────────────────────────────────────────
VITE_DEFAULT_THEME=system
VITE_STORAGE_PREFIX=techfolks
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# ── Rate Limits ───────────────────────────────────────────────
VITE_MAX_SUBMISSIONS_PER_MINUTE=5

# ── Monaco Editor ─────────────────────────────────────────────
VITE_MONACO_THEMES=vs-dark,vs-light,hc-black

# ── Third-Party Services (set real values in Render dashboard) ─
# VITE_GITHUB_CLIENT_ID=
# VITE_GOOGLE_CLIENT_ID=
# VITE_GA_TRACKING_ID=
# VITE_SENTRY_DSN=
