# =============================================================
#  Dezolver — Staging Environment
#  Used when VITE_ENV=staging (e.g. preview / QA deployments)
#
#  ⚠️  Do NOT commit real secrets to this file.
#      Replace placeholder URLs with your actual staging URLs.
# =============================================================

# ── Environment identity ──────────────────────────────────────
VITE_ENV=staging

# ── API ───────────────────────────────────────────────────────
# Replace with your actual staging backend URL once deployed.
# The /api suffix is required — it is used as the raw Axios baseURL.
VITE_API_URL=https://dezolver-backend-staging.onrender.com/api

# ── WebSocket ─────────────────────────────────────────────────
# Must use wss:// (secure) for any HTTPS-served staging site.
VITE_WS_URL=wss://dezolver-backend-staging.onrender.com

# ── App metadata ──────────────────────────────────────────────
VITE_APP_NAME=Dezolver (Staging)
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Competitive coding platform — staging environment

# ── Request timeouts (ms) ─────────────────────────────────────
VITE_API_TIMEOUT=15000
VITE_UPLOAD_TIMEOUT=60000

# ── Auth ──────────────────────────────────────────────────────
VITE_AUTH_TOKEN_KEY=techfolks_auth_token
VITE_REFRESH_TOKEN_KEY=techfolks_refresh_token
VITE_SESSION_TIMEOUT=604800000
VITE_MAX_LOGIN_ATTEMPTS=5

# ── Feature flags ─────────────────────────────────────────────
# Keep all features enabled on staging so they can be tested
# before being promoted to production.
VITE_ENABLE_GROUPS=true
VITE_ENABLE_CONTESTS=true
VITE_ENABLE_DISCUSSIONS=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_ADMIN_CONSOLE=true
VITE_ENABLE_SOCIAL_AUTH=true
VITE_ENABLE_CODE_EXECUTION=true

# ── UI ────────────────────────────────────────────────────────
VITE_DEFAULT_THEME=system
VITE_STORAGE_PREFIX=techfolks
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# ── Rate limits ───────────────────────────────────────────────
VITE_MAX_SUBMISSIONS_PER_MINUTE=5

# ── Monaco editor ─────────────────────────────────────────────
VITE_MONACO_THEMES=vs-dark,vs-light,hc-black

# ── External / third-party (optional) ────────────────────────
# VITE_GITHUB_CLIENT_ID=
# VITE_GOOGLE_CLIENT_ID=
# VITE_GA_TRACKING_ID=
# VITE_SENTRY_DSN=
